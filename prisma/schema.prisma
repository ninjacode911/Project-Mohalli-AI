// ============================================================
// Mohalla AI — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Persistent geocoding cache (30-day TTL, managed at application level)
model GeocodeCache {
  id               String   @id @default(cuid())
  areaText         String
  lat              Float
  lng              Float
  formattedAddress String
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  @@unique([areaText])
  @@map("geocode_cache")
}

/// Search analytics — logs every search for analytics and popular areas
model SearchLog {
  id           String   @id @default(cuid())
  areaText     String
  lat          Float
  lng          Float
  category     String
  resultsCount Int
  userAgent    String   @default("")
  timestamp    DateTime @default(now())

  @@index([areaText])
  @@index([category])
  @@index([timestamp])
  @@map("search_log")
}

/// Auto-populated from SearchLog — powers "Popular Areas" suggestions
model PopularArea {
  id           String   @id @default(cuid())
  areaName     String
  city         String
  state        String   @default("")
  lat          Float
  lng          Float
  searchCount  Int      @default(0)
  lastSearched DateTime @default(now())

  @@unique([areaName, city])
  @@index([searchCount(sort: Desc)])
  @@map("popular_areas")
}
