# ============================================================
# Mohalla AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# TomTom — Server-side API key (for geocoding, search, details)
TOMTOM_API_KEY=your_tomtom_api_key_here

# TomTom — Client-side API key (for map tiles, exposed to browser)
NEXT_PUBLIC_TOMTOM_API_KEY=your_tomtom_api_key_here

# Redis (Upstash) — optional, uses in-memory fallback if not set
REDIS_URL=

# PostgreSQL (Supabase / Neon) — optional, analytics disabled if not set
DATABASE_URL=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (optional — for error monitoring)
SENTRY_DSN=
