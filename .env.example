# ============================================================
# Mohalla AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# Google Maps — Server-side API key (unrestricted by referrer, restricted by IP)
GOOGLE_MAPS_API_KEY=your_server_side_key_here

# Google Maps — Client-side API key (restricted by referrer to your domain)
NEXT_PUBLIC_GOOGLE_MAPS_CLIENT_KEY=your_client_side_key_here

# Google Maps — Map ID for custom styling (optional)
NEXT_PUBLIC_GOOGLE_MAP_ID=

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# PostgreSQL (Supabase / Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/mohalla_ai

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (optional — for error monitoring)
SENTRY_DSN=
